# Local development only. GitHub Pages ignores this and builds the
# site for you on push. To preview locally:
#
#   bundle install
#   bundle exec jekyll serve --livereload
#
# then open http://localhost:4000/boamm/

source "https://rubygems.org"

# Matches the version GitHub Pages runs, so local == production.
gem "github-pages", group: :jekyll_plugins

gem "jekyll-feed"
gem "jekyll-seo-tag"

# Windows / JRuby niceties (harmless elsewhere).
gem "tzinfo-data", platforms: [:mingw, :mswin, :x64_mingw, :jruby]
gem "wdm", "~> 0.1.1", platforms: [:mingw, :mswin, :x64_mingw]
